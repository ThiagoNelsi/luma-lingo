generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_MIGRATION_URL")
}

enum OnboardingStatus {
  not_started
  in_progress
  completed

  @@map("onboarding_status")
}

enum ProfileIntroductionStatus {
  not_started
  pending
  processing
  completed
  failed
  manual_required

  @@map("profile_introduction_status")
}

model User {
  id              String         @id @db.Uuid
  primaryEmail    String         @map("primary_email")
  emailVerifiedAt DateTime       @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt     DateTime?      @map("last_login_at") @db.Timestamptz(6)
  authIdentities  AuthIdentity[]
  learner         Learner?
  sessions        Session[]

  @@map("users")
}

model AuthIdentity {
  id              String    @id @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String
  providerSubject String    @map("provider_subject")
  emailAtAuthTime String    @map("email_at_auth_time")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt      DateTime? @map("last_seen_at") @db.Timestamptz(6)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_identities")
}

model Session {
  id         String    @id @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt DateTime  @map("last_seen_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Learner {
  id                     String               @id @db.Uuid
  userId                 String               @unique @map("user_id") @db.Uuid
  displayName            String?              @map("display_name")
  instructionLanguage    String?              @map("instruction_language")
  ageRange               String?              @map("age_range")
  ageRangeDeclaredAt     DateTime?            @map("age_range_declared_at") @db.Timestamptz(6)
  currentLearningTrackId String?              @unique @map("current_learning_track_id") @db.Uuid
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLearningTrack   LearningTrack?       @relation("CurrentLearningTrack", fields: [currentLearningTrackId], references: [id], onDelete: SetNull)
  learningTracks         LearningTrack[]      @relation("LearnerLearningTracks")
  profileIntroduction    ProfileIntroduction?

  @@map("learners")
}

model ProfileIntroduction {
  id           String                    @id @db.Uuid
  learnerId    String                    @unique @map("learner_id") @db.Uuid
  status       ProfileIntroductionStatus @default(not_started)
  attempts     Int                       @default(0)
  errorCode    String?                   @map("error_code")
  jobOrField   String?                   @map("job_or_field")
  interests    String[]                  @default([])
  dailyRoutine String[]                  @default([]) @map("daily_routine")
  studyContext String?                   @map("study_context")
  other        String[]                  @default([])
  createdAt    DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  learner      Learner                   @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@map("profile_introductions")
}

model LearningTrack {
  id                      String                   @id @db.Uuid
  learnerId               String                   @map("learner_id") @db.Uuid
  targetLanguage          String                   @map("target_language")
  level                   String?
  learningGoal            String?                  @map("learning_goal")
  goalCefrLevel           String?                  @map("goal_cefr_level")
  additionalGoals         String[]                 @default([]) @map("additional_goals")
  lessonEmphases          String[]                 @default([]) @map("lesson_emphases")
  studyPace               String?                  @map("study_pace")
  onboardingStartingPoint String?                  @map("onboarding_starting_point")
  competencyCatalogId     String?                  @map("competency_catalog_id") @db.Uuid
  onboardingStatus        OnboardingStatus         @default(not_started) @map("onboarding_status")
  onboardingStep          String?                  @map("onboarding_step")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  learner                 Learner                  @relation("LearnerLearningTracks", fields: [learnerId], references: [id], onDelete: Cascade)
  competencyCatalog       CompetencyCatalog?       @relation(fields: [competencyCatalogId], references: [id], onDelete: SetNull)
  diagnosticAttempts      DiagnosticAttempt[]
  competencyStates        LearnerCompetencyState[]
  competencyEvidence      CompetencyEvidence[]
  currentForLearner       Learner?                 @relation("CurrentLearningTrack")

  @@unique([learnerId, targetLanguage])
  @@index([competencyCatalogId])
  @@map("learning_tracks")
}

model CompetencyCatalog {
  id                 String              @id @db.Uuid
  targetLanguage     String              @map("target_language")
  version            String
  status             String              @default("draft")
  publishedAt        DateTime?           @map("published_at") @db.Timestamptz(6)
  sourceChecksum     String?             @map("source_checksum")
  metadata           Json                @default("{}")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  learningTracks     LearningTrack[]
  competencies       Competency[]
  diagnosticItems    DiagnosticItem[]
  diagnosticAttempts DiagnosticAttempt[]

  @@unique([targetLanguage, version])
  @@index([targetLanguage, status])
  @@map("competency_catalogs")
}

model Competency {
  id                       String                           @id @db.Uuid
  catalogId                String                           @map("catalog_id") @db.Uuid
  key                      String
  title                    String
  description              String?
  family                   String
  difficultyBand           String?                          @map("difficulty_band")
  taxonomyId               String                           @map("taxonomy_id")
  estimatedDifficultyScore Float?                           @map("estimated_difficulty_score")
  status                   String                           @default("draft")
  details                  Json                             @default("{}")
  createdAt                DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  catalog                  CompetencyCatalog                @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  conceptRelationships     CompetencyConcept[]
  primaryDiagnosticItems   DiagnosticItem[]                 @relation("PrimaryDiagnosticCompetency")
  diagnosticItemTargets    DiagnosticItemCompetencyTarget[]
  learnerStates            LearnerCompetencyState[]
  evidence                 CompetencyEvidence[]

  @@unique([catalogId, key])
  @@index([catalogId, family])
  @@index([catalogId, difficultyBand])
  @@index([catalogId, taxonomyId])
  @@index([catalogId, status])
  @@map("competencies")
}

model Concept {
  id                      String              @id @db.Uuid
  targetLanguage          String              @map("target_language")
  key                     String
  label                   String
  aliases                 String[]            @default([])
  status                  String              @default("draft")
  replacedByConceptId     String?             @map("replaced_by_concept_id") @db.Uuid
  details                 Json                @default("{}")
  createdAt               DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  replacedBy              Concept?            @relation("ConceptReplacement", fields: [replacedByConceptId], references: [id], onDelete: Restrict)
  replacements            Concept[]           @relation("ConceptReplacement")
  competencyRelationships CompetencyConcept[]

  @@unique([targetLanguage, key])
  @@index([targetLanguage, status])
  @@index([replacedByConceptId])
  @@map("concepts")
}

model CompetencyConcept {
  competencyId       String     @map("competency_id") @db.Uuid
  conceptId          String     @map("concept_id") @db.Uuid
  role               String
  requiredCapability String?    @map("required_capability")
  details            Json       @default("{}")
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  competency         Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  concept            Concept    @relation(fields: [conceptId], references: [id], onDelete: Restrict)

  @@id([competencyId, conceptId])
  @@index([conceptId, role])
  @@index([role, requiredCapability])
  @@map("competency_concepts")
}

model DiagnosticItem {
  id                  String                           @id @db.Uuid
  catalogId           String                           @map("catalog_id") @db.Uuid
  key                 String
  primaryCompetencyId String                           @map("primary_competency_id") @db.Uuid
  difficultyBand      String                           @map("difficulty_band")
  responseFormat      String                           @map("response_format")
  status              String                           @default("draft")
  prompt              Json
  scoringRule         Json                             @map("scoring_rule")
  details             Json                             @default("{}")
  reviewedAt          DateTime?                        @map("reviewed_at") @db.Timestamptz(6)
  publishedAt         DateTime?                        @map("published_at") @db.Timestamptz(6)
  createdAt           DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  catalog             CompetencyCatalog                @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  primaryCompetency   Competency                       @relation("PrimaryDiagnosticCompetency", fields: [primaryCompetencyId], references: [id], onDelete: Restrict)
  competencyTargets   DiagnosticItemCompetencyTarget[]
  attemptItems        DiagnosticAttemptItem[]

  @@unique([catalogId, key])
  @@index([catalogId, status, difficultyBand])
  @@index([primaryCompetencyId])
  @@map("diagnostic_items")
}

model DiagnosticItemCompetencyTarget {
  diagnosticItemId String         @map("diagnostic_item_id") @db.Uuid
  competencyId     String         @map("competency_id") @db.Uuid
  role             String
  weight           Int?
  details          Json           @default("{}")
  diagnosticItem   DiagnosticItem @relation(fields: [diagnosticItemId], references: [id], onDelete: Cascade)
  competency       Competency     @relation(fields: [competencyId], references: [id], onDelete: Restrict)

  @@id([diagnosticItemId, competencyId])
  @@index([competencyId])
  @@map("diagnostic_item_competency_targets")
}

model DiagnosticAttempt {
  id                     String                  @id @db.Uuid
  learningTrackId        String                  @map("learning_track_id") @db.Uuid
  catalogId              String                  @map("catalog_id") @db.Uuid
  purpose                String
  status                 String                  @default("in_progress")
  selectionPolicyVersion String                  @map("selection_policy_version")
  scoringPolicyVersion   String                  @map("scoring_policy_version")
  startedAt              DateTime                @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt            DateTime?               @map("completed_at") @db.Timestamptz(6)
  abandonedAt            DateTime?               @map("abandoned_at") @db.Timestamptz(6)
  summary                Json                    @default("{}")
  details                Json                    @default("{}")
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  learningTrack          LearningTrack           @relation(fields: [learningTrackId], references: [id], onDelete: Cascade)
  catalog                CompetencyCatalog       @relation(fields: [catalogId], references: [id], onDelete: Restrict)
  items                  DiagnosticAttemptItem[]

  @@index([learningTrackId, status])
  @@index([learningTrackId, purpose, status])
  @@index([catalogId])
  @@map("diagnostic_attempts")
}

model DiagnosticAttemptItem {
  id               String            @id @db.Uuid
  attemptId        String            @map("attempt_id") @db.Uuid
  diagnosticItemId String            @map("diagnostic_item_id") @db.Uuid
  position         Int
  selectedForRole  String            @map("selected_for_role")
  selectionRule    String            @map("selection_rule")
  selectionTrace   Json              @default("{}") @map("selection_trace")
  response         Json?
  score            Float?
  confidence       Float?
  shownAt          DateTime          @default(now()) @map("shown_at") @db.Timestamptz(6)
  answeredAt       DateTime?         @map("answered_at") @db.Timestamptz(6)
  details          Json              @default("{}")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  attempt          DiagnosticAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  diagnosticItem   DiagnosticItem    @relation(fields: [diagnosticItemId], references: [id], onDelete: Restrict)

  @@unique([attemptId, position])
  @@unique([attemptId, diagnosticItemId])
  @@index([diagnosticItemId])
  @@index([selectedForRole])
  @@index([selectionRule])
  @@map("diagnostic_attempt_items")
}

model LearnerCompetencyState {
  id              String        @id @db.Uuid
  learningTrackId String        @map("learning_track_id") @db.Uuid
  competencyId    String        @map("competency_id") @db.Uuid
  abilityEstimate Float?        @map("ability_estimate")
  confidence      Float         @default(0)
  evidenceCount   Int           @default(0) @map("evidence_count")
  lastEvidenceAt  DateTime?     @map("last_evidence_at") @db.Timestamptz(6)
  details         Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  learningTrack   LearningTrack @relation(fields: [learningTrackId], references: [id], onDelete: Cascade)
  competency      Competency    @relation(fields: [competencyId], references: [id], onDelete: Restrict)

  @@unique([learningTrackId, competencyId])
  @@index([competencyId])
  @@map("learner_competency_states")
}

model CompetencyEvidence {
  id              String        @id @db.Uuid
  learningTrackId String        @map("learning_track_id") @db.Uuid
  competencyId    String        @map("competency_id") @db.Uuid
  sourceType      String        @map("source_type")
  sourceId        String?       @map("source_id")
  observedAt      DateTime      @default(now()) @map("observed_at") @db.Timestamptz(6)
  score           Float?
  confidence      Float?
  details         Json          @default("{}")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  learningTrack   LearningTrack @relation(fields: [learningTrackId], references: [id], onDelete: Cascade)
  competency      Competency    @relation(fields: [competencyId], references: [id], onDelete: Restrict)

  @@index([learningTrackId, observedAt])
  @@index([competencyId])
  @@index([sourceType, sourceId])
  @@map("competency_evidence")
}
