{
  "name": "@luma-lingo/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "check": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/luma_lingo} DATABASE_MIGRATION_URL=${DATABASE_MIGRATION_URL:-postgresql://user:password@localhost:5432/luma_lingo} prisma validate && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:import:concepts": "dotenv -e ../../.env -- tsx scripts/import-concept-registry.ts",
    "db:import:competencies": "dotenv -e ../../.env -- tsx scripts/import-competency-catalog.ts",
    "db:import:policy": "dotenv -e ../../.env -- tsx scripts/import-pedagogical-policy.ts",
    "db:verify:authorial-catalog": "dotenv -e ../../.env -- tsx scripts/verify-authorial-catalog.ts",
    "db:import:diagnostic-questions": "dotenv -e ../../.env -- tsx scripts/import-diagnostic-question-bank.ts",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@luma-lingo/shared": "workspace:*",
    "@prisma/client": "6.19.3",
    "uuid": "latest"
  },
  "devDependencies": {
    "dotenv-cli": "latest",
    "prisma": "6.19.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
