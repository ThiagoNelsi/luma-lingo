{
  "name": "language-guru",
  "version": "0.1.0",
  "private": true,
  "description": "LumaLingo TypeScript monorepo.",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "pnpm --parallel -r dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
