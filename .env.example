# Local development
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:3000

# Postgres
# Use the pooled Neon connection string for app runtime when available.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/luma_lingo?sslmode=require
# Optional direct connection string for migrations. Falls back to DATABASE_URL when unset.
DATABASE_MIGRATION_URL=

# Cognito Managed Login
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_APP_CLIENT_ID=example_client_id
COGNITO_APP_CLIENT_SECRET=example_client_secret
COGNITO_DOMAIN=https://example.auth.us-east-1.amazoncognito.com
AUTH_CALLBACK_URL=http://localhost:3000/auth/callback
AUTH_LOGOUT_URL=http://localhost:5173/login

# App-owned web session
SESSION_COOKIE_NAME=luma_lingo_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_DAYS=7

# Web app public config
VITE_API_ORIGIN=http://localhost:3000
VITE_AUTH_LOGIN_URL=http://localhost:3000/auth/login
VITE_FRONTEND_ORIGIN=http://localhost:5173
