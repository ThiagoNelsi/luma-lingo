{
  "name": "luma-lingo",
  "version": "0.1.0",
  "private": true,
  "description": "LumaLingo TypeScript monorepo.",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "db:generate": "pnpm --filter @luma-lingo/database db:generate",
    "db:migrate": "pnpm --filter @luma-lingo/database db:migrate",
    "db:studio": "pnpm --filter @luma-lingo/database db:studio",
    "dev": "pnpm --parallel -r dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "pnpm -r test",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.9",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
